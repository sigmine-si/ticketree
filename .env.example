# 로컬 개발
DATABASE_URL=postgres://ticketree:ticketree@localhost:5433/ticketree

# 러너
RUNNER_POLL_MS=2000
RUNNER_MAX_CONCURRENT=2

# 에이전트 인증 (§10)
# 로컬에서는 `claude` CLI 로그인 상태를 그대로 쓰므로 비워둬도 된다.
# 서버에서는 `claude setup-token`으로 만든 토큰을 넣는다.
# CLAUDE_CODE_OAUTH_TOKEN=

# 관리자 인증 (§16-1) — 슬라이스 2
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# ADMIN_GITHUB_LOGINS=jiwoochris
