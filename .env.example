# 로컬 개발
DATABASE_URL=postgres://ticketree:ticketree@localhost:5433/ticketree

# 러너
RUNNER_POLL_MS=2000
RUNNER_MAX_CONCURRENT=2

# 에이전트 인증 (§10)
# 로컬에서는 `claude` CLI 로그인 상태를 그대로 쓰므로 비워둬도 된다.
# 서버에서는 `claude setup-token`으로 만든 토큰을 넣는다.
# CLAUDE_CODE_OAUTH_TOKEN=

# 관리자 인증 (§16-1) — 아이디 + 비밀번호
# 둘 중 하나라도 비어 있으면 관리자 로그인이 열리지 않는다.
ADMIN_ID=
ADMIN_PASSWORD=

# 세션 서명 키 (프로덕션에서는 반드시 교체)
SESSION_SECRET=dev-only-insecure-secret
APP_ORIGIN=http://localhost:3000

# 원가 표시용 고정 환율 — 정산에 쓰지 않는다 (§8)
USD_TO_KRW=1400
